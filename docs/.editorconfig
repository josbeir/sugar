root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.yml]
indent_style = space
indent_size = 2

[*.neon]
indent_style = tab
indent_size = 4

[*.dj]
indent_style = space
indent_size = 2

[*.md]
indent_style = space

[*.{js,jsx,mjs,cjs,ts,tsx}]
indent_style = space
indent_size = 2
