pageTemplate: page
extensions:
	- sitemap
	- llms-txt
	- search-index
site:
	title: Sugar
	description: A modern PHP templating engine that compiles to pure PHP
	baseUrl: https://josbeir.github.io/
	basePath: /sugar
	repository: https://github.com/josbeir/sugar
	footer: Created by Jasper Smet.
	license: MIT License
	licenseLink: https://github.com/josbeir/sugar/blob/main/LICENSE.md
	logo: /sugar-cube-static.svg

djot:
	codeHighlighting:
		enabled: true
		themes:
			dark: github-dark-default
			light: light-plus
		withGutter: false
	headerAnchors:
		enabled: true

build:
	vite:
		enabled: true
		command: npm run build
		defaultEntry: assets/css/site.css

devServer:
	vite:
		enabled: true
		host: '127.0.0.1'
		port: 5175
		command: 'npm run dev -- --host {host} --port {port} --strictPort'
		defaultEntry: assets/css/site.css


